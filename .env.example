# ─── Supabase ──────────────────────────────────────────────────────────────
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the client. Used for
# privileged writes (e.g. fulfilling a subscription from a Stripe webhook).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (scaffolded — not wired up yet) ──────────────────────────────────
# Publishable key is safe for the browser. Secret + webhook keys are SERVER ONLY.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
# Base URL used for redirects (Stripe success/cancel, auth callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000
